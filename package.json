{
  "name": "veggiekarte",
  "version": "2.9.0",
  "description": "A OpenStreetMap based map to easily find places, like restaurants and cafes, with vegetarian and vegan options.",
  "repository": {
    "type": "git",
    "url": "https://codeberg.org/piratenpanda/veggiekarte"
  },
  "keywords": [
    "vegan",
    "map"
  ],
  "author": {
    "name": "piratenpanda",
    "url": "https://codeberg.org/piratenpanda"
  },
  "contributors": [
    "https://codeberg.org/piratenpanda/veggiekarte/activity/contributors"
  ],
  "license": "GPL-3.0-only",
  "bugs": {
    "url": "https://codeberg.org/piratenpanda/veggiekarte/issues"
  },
  "homepage": "https://veggiekarte.de/",
  "devDependencies": {
    "@eslint/css": "^1.0.0",
    "@eslint/js": "^10.0.1",
    "@eslint/markdown": "^7.5.1",
    "@mapbox/maki": "^8.2.0",
    "@rapideditor/temaki": "^5.12.0",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^10.0.3",
    "eslint-plugin-import-x": "^4.16.2",
    "globals": "^17.4.0",
    "lightningcss-cli": "^1.32.0",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "rollup": "^4.59.0",
    "simple-git-hooks": "^2.13.1"
  },
  "dependencies": {
    "@kristjan.esperanto/leaflet-language-selector": "^3.4.0",
    "@kristjan.esperanto/leaflet.markercluster": "^3.0.2",
    "chart.js": "^4.5.1",
    "email-validator": "^2.0.4",
    "leaflet": "^2.0.0-alpha.1",
    "leaflet-control-geocoder": "^3.3.1",
    "leaflet-theme-control": "^0.1.4",
    "leaflet.fullscreen": "^5.3.0",
    "leaflet.locatecontrol": "^0.89.0",
    "libphonenumber-js": "^1.12.39",
    "opening_hours": "^3.11.0"
  },
  "overrides": {
    "leaflet-control-geocoder": {
      "leaflet": "$leaflet"
    }
  },
  "scripts": {
    "build": "node scripts/generate_icons.js && rollup -c && lightningcss --minify --bundle css/main.css -o css/bundle.css",
    "bump": "npx bumpp package.json service-worker.js --all --no-push --execute=\"npm run build\"",
    "datacheck": "node ./datacheck/datacheck.js",
    "lint": "eslint && prettier . --check",
    "lint:fix": "eslint --fix && prettier . --write",
    "prepare": "simple-git-hooks",
    "refresh": "python3 refresh.py",
    "release": "node --run lint:fix && node --run bump",
    "test": "node --run lint"
  },
  "type": "module",
  "lint-staged": {
    "*": [
      "eslint --fix",
      "prettier --write --ignore-unknown"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  }
}
